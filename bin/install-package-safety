#!/bin/sh

set -eu

SCRIPT_DIR=$(CDPATH= cd -- "$(dirname "$0")" && pwd)
REPO_ROOT=$(CDPATH= cd -- "$SCRIPT_DIR/.." && pwd)

BIN_DIR=${PACKAGE_SAFETY_BIN_DIR:-$HOME/.local/bin}
PLIST_DIR=${PACKAGE_SAFETY_PLIST_DIR:-$HOME/Library/LaunchAgents}
LOG_DIR=${PACKAGE_SAFETY_LOG_DIR:-$HOME/Library/Logs}
LABEL=${PACKAGE_SAFETY_LABEL:-local.package-safety.refresh}
WEEKDAY=${PACKAGE_SAFETY_WEEKDAY:-1}
HOUR=${PACKAGE_SAFETY_HOUR:-9}
MINUTE=${PACKAGE_SAFETY_MINUTE:-0}

BOOTSTRAP_SRC="$REPO_ROOT/bin/package-safety-bootstrap"
REFRESH_SRC="$REPO_ROOT/bin/package-safety-refresh-weekly"
LIB_SRC="$REPO_ROOT/bin/package-safety-global-lib.sh"
PIP_WRAPPER_SRC="$REPO_ROOT/bin/pip-uv-wrapper"
PLIST_TEMPLATE="$REPO_ROOT/launchd/local.package-safety.refresh.plist.template"

BOOTSTRAP_DEST="$BIN_DIR/package-safety-bootstrap"
REFRESH_DEST="$BIN_DIR/package-safety-refresh-weekly"
LIB_DEST="$BIN_DIR/package-safety-global-lib.sh"
PIP_WRAPPER_DEST="$BIN_DIR/pip"
PIP3_WRAPPER_DEST="$BIN_DIR/pip3"
PLIST_DEST="$PLIST_DIR/$LABEL.plist"
LOG_FILE="$LOG_DIR/package-safety-refresh.log"

LOAD_AGENT=0
RUN_BOOTSTRAP=0

usage() {
  cat <<'EOF'
Usage: install-package-safety [--load-agent] [--run-bootstrap]

Installs the package safety scripts into ~/.local/bin by default and writes a
LaunchAgent plist into ~/Library/LaunchAgents by default.

Default behavior:
  Installs files only. Does not apply package-manager settings yet and does not
  load the LaunchAgent yet.

Options:
  --run-bootstrap  Run package-safety-bootstrap after installation. This
                   applies the settings now and clears caches once.
  --load-agent     Load or reload the LaunchAgent after writing the plist.
                   Because the plist uses RunAtLoad, this immediately runs the
                   weekly refresh once, then again on future logins and the
                   weekly schedule.
  --help           Show this help.

Environment overrides:
  PACKAGE_SAFETY_BIN_DIR
  PACKAGE_SAFETY_PLIST_DIR
  PACKAGE_SAFETY_LOG_DIR
  PACKAGE_SAFETY_LABEL
  PACKAGE_SAFETY_WEEKDAY
  PACKAGE_SAFETY_HOUR
  PACKAGE_SAFETY_MINUTE
EOF
}

log() {
  printf '%s\n' "$*"
}

escape_sed() {
  printf '%s' "$1" | sed -e 's/[\/&]/\\&/g'
}

render_plist() {
  sed \
    -e "s/__LABEL__/$(escape_sed "$LABEL")/g" \
    -e "s/__WEEKLY_SCRIPT__/$(escape_sed "$REFRESH_DEST")/g" \
    -e "s/__LOG_FILE__/$(escape_sed "$LOG_FILE")/g" \
    -e "s/__WEEKDAY__/$(escape_sed "$WEEKDAY")/g" \
    -e "s/__HOUR__/$(escape_sed "$HOUR")/g" \
    -e "s/__MINUTE__/$(escape_sed "$MINUTE")/g" \
    "$PLIST_TEMPLATE" > "$PLIST_DEST"
}

load_agent() {
  launchctl bootout "gui/$(id -u)" "$PLIST_DEST" >/dev/null 2>&1 || true
  launchctl bootstrap "gui/$(id -u)" "$PLIST_DEST"
}

while [ $# -gt 0 ]; do
  case "$1" in
    --load-agent)
      LOAD_AGENT=1
      ;;
    --run-bootstrap)
      RUN_BOOTSTRAP=1
      ;;
    --help)
      usage
      exit 0
      ;;
    *)
      printf 'Unknown option: %s\n' "$1" >&2
      usage >&2
      exit 1
      ;;
  esac
  shift
done

install -d "$BIN_DIR" "$PLIST_DIR" "$LOG_DIR"
install -m 755 "$LIB_SRC" "$LIB_DEST"
install -m 755 "$BOOTSTRAP_SRC" "$BOOTSTRAP_DEST"
install -m 755 "$REFRESH_SRC" "$REFRESH_DEST"
install -m 755 "$PIP_WRAPPER_SRC" "$PIP_WRAPPER_DEST"
install -m 755 "$PIP_WRAPPER_SRC" "$PIP3_WRAPPER_DEST"
render_plist

log "Installed scripts:"
log "  $LIB_DEST"
log "  $BOOTSTRAP_DEST"
log "  $REFRESH_DEST"
log "Installed pip/pip3 uv wrappers:"
log "  $PIP_WRAPPER_DEST"
log "  $PIP3_WRAPPER_DEST"
log "Installed LaunchAgent plist:"
log "  $PLIST_DEST"

if [ "$RUN_BOOTSTRAP" -eq 1 ]; then
  "$BOOTSTRAP_DEST"
else
  log "Bootstrap not run. Settings have not been applied by bootstrap."
  log "To apply settings now with cache clearing:"
  log "  $BOOTSTRAP_DEST"
fi

if [ "$LOAD_AGENT" -eq 1 ]; then
  load_agent
  log "LaunchAgent loaded. Because RunAtLoad is enabled, the weekly refresh"
  log "will run once now, then again on login and on the weekly schedule."
else
  log "LaunchAgent not loaded. To load it now:"
  log "  launchctl bootstrap gui/$(id -u) \"$PLIST_DEST\""
  log "That will also run the weekly refresh once immediately."
fi
